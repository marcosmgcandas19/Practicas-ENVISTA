<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
        VISTA DE FORMULARIO DEL ASISTENTE DE VENTA RÁPIDA DE ENTRADAS
        Permite vender entradas de forma rápida, seleccionar butacas,
        aplicar fidelización y canjear puntos.
    -->
    <record id="view_ticket_wizard_form" model="ir.ui.view">
        <field name="name">cinenvista.ticket.wizard.form</field>
        <field name="model">cinenvista.ticket.wizard</field>
        <field name="arch" type="xml">
            <form>
                <!-- BOTONES DE ACCIÓN -->
                <header>
                    <button 
                        name="action_confirm_sale"
                        string="Confirmar Venta"
                        type="object"
                        class="oe_highlight"
                        help="Procesa la venta: crear orden, reserva y actualizar puntos"/>
                    <button
                        string="Cancelar"
                        class="btn-secondary"
                        special="cancel"
                        help="Cierra el asistente sin guardar cambios"/>
                </header>

                <sheet>
                    <!-- TÍTULO DEL ASISTENTE -->
                    <div class="oe_title">
                        <h1>Venta Rápida de Entradas</h1>
                    </div>

                    <!-- CAMPOS OCULTOS -->
                    <field name="room_id" invisible="1"/>
                    <field name="occupied_seat_ids" invisible="1"/>

                    <!-- SECCIÓN 1: INFORMACIÓN GENERAL -->
                    <group>
                        <group string="Información General">
                            <field
                                name="screening_id"
                                options="{'no_create': True, 'no_open': True}"/>
                            <field
                                name="partner_id"
                                options="{'no_create_edit': True}"/>
                        </group>

                        <!-- SECCIÓN 2: CANTIDADES DE ENTRADAS -->
                        <group string="Cantidades">
                            <field name="qty_regular"/>
                            <field name="qty_vip"/>
                        </group>
                    </group>

                    <!-- NOTEBOOK PARA TABS -->
                    <notebook>
                        <!-- TAB 1: ENTRADAS Y FIDELIZACIÓN -->
                        <page string="Entradas" name="entries_tab">
                            <!-- PROGRAMA DE FIDELIZACIÓN -->
                            <group string="Programa de Fidelización">
                                <field name="partner_id" invisible="1"/>
                                <group>
                                    <field
                                        name="redeem_points"
                                        widget="boolean_toggle"/>
                                    <field
                                        name="available_points"
                                        readonly="1"/>
                                </group>
                            </group>
                            
                            <!-- SELECCIÓN DE BUTACAS -->
                            <group string="Selección de Asientos">
                                <field
                                    name="selected_seat_ids"
                                    widget="many2many_tags"
                                    options="{'no_create': True}"
                                    placeholder="Selecciona las butacas (debe coincidir con el total de entradas)"/>
                            </group>
                        </page>

                        <!-- TAB 2: SNACKS & BEBIDAS (CONSUMIBLES) -->
                        <page string="Snacks &amp; Bebidas" name="consumables_tab">
                            <p class="oe_inline" style="font-size:14px;">
                                Añade productos del bar para aumentar el ticket promedio
                            </p>
                            <field
                                name="consumable_line_ids"
                                widget="one2many"
                                mode="tree">
                                <tree editable="bottom" create="true" delete="true">
                                    <field name="product_id" required="1"/>
                                    <field name="quantity" required="1"/>
                                    <field name="price_unit" readonly="1"/>
                                    <field name="subtotal" readonly="1"/>
                                    <field name="stock_available" readonly="1"/>
                                </tree>
                            </field>
                            
                            <!-- TOTAL DE CONSUMIBLES -->
                            <div class="row">
                                <div class="col-6"></div>
                                <div class="col-6">
                                    <div class="alert alert-info">
                                        <strong>Total Consumibles:</strong>
                                        <span class="float-right">
                                            <field name="consumable_total" widget="monetary" readonly="1"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 
        ACCIÓN: Abre el asistente de venta rápida
        Tipo: ventana emergente (tipo modal)
    -->
    <record id="action_ticket_wizard" model="ir.actions.act_window">
        <field name="name">Venta Rápida de Entradas</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">cinenvista.ticket.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="help">Asistente para realizar ventas rápidas de entradas, seleccionar butacas específicas y aplicar programas de fidelización</field>
    </record>

    <menuitem id="menu_ticket_wizard" name="Venta Rápida" parent="menu_cinenvista_root" 
              action="action_ticket_wizard" sequence="50"/>
</odoo> 