<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ VISTAS DEL BACKEND ============ -->
    
    <record id="view_movie_tree" model="ir.ui.view">
        <field name="name">cinenvista.movie.tree</field>
        <field name="model">cinenvista.movie</field>
        <field name="arch" type="xml">
            <tree>
                <field name="title"/>
                <field name="rating"/>
                <field name="state"/>
                <field name="release_date"/>
                <field name="duration"/>
            </tree>
        </field>
    </record>

    <record id="view_movie_form" model="ir.ui.view">
        <field name="name">cinenvista.movie.form</field>
        <field name="model">cinenvista.movie</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_get_movie" 
                            string="Actualizar desde TMDB" 
                            type="object" 
                            class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="title" placeholder="Título de la película"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Información Básica">
                            <field name="state"/>
                            <field name="rating"/>
                            <field name="duration"/>
                            <field name="release_date"/>
                        </group>
                        <group string="Integración TMDB">
                            <field name="tmdb_id"/>
                            <field name="image_url"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" widget="html" placeholder="Sinopsis o descripción de la película"/>
                    </group>
                    <group string="Clasificación">
                        <field name="tag_ids" widget="many2many_tags"/>
                    </group>
                    <notebook>
                        <page string="Sesiones" name="sesiones">
                            <field name="screening_ids">
                                <tree editable="bottom">
                                    <field name="room_id"/>
                                    <field name="start_time"/>
                                    <field name="available_seats" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cinenvista_movie" model="ir.actions.act_window">
        <field name="name">Películas</field>
        <field name="res_model">cinenvista.movie</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_movie" name="Películas" parent="menu_cinenvista_root" 
              action="action_cinenvista_movie" sequence="10"/>

    <!-- ============ PLANTILLAS WEBSITE ============ -->

    <template id="movie_template" name="Cinenvista Movie Detail">
        <t t-call="website.layout">
            <div id="wrap" class="cinenvista-movie-detail">
                <div class="container py-5">
                    <div class="row">
                        <div class="col-lg-4 mb-4">
                            <div class="movie-poster-container">
                                <img t-if="movie['image_url']" t-att-src="movie['image_url']" 
                                     class="img-fluid rounded shadow-lg movie-poster" t-att-alt="movie['title']"/>
                                <div t-else="" class="bg-secondary d-flex align-items-center justify-content-center rounded movie-poster" style="height: 500px; width: 100%;">
                                    <span class="display-1 text-white-50">🎬</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-8">
                            <div class="movie-header mb-4">
                                <h1 class="movie-title mb-2" t-esc="movie['title']"/>
                                <div class="d-flex align-items-center gap-3">
                                    <span class="badge badge-pill p-2" style="background-color: #FFA500; color: white;">
                                        <i class="fa fa-star me-1"/> <t t-esc="movie['rating']"/>
                                    </span>
                                    <t t-foreach="movie.get('tag_ids', [])" t-as="tag">
                                        <span class="badge badge-pill py-2 px-3" 
                                              t-attf-style="background-color: {{tag['hex_color']}}; color: white;" 
                                              t-esc="tag['name']"/>
                                    </t>
                                </div>
                            </div>

                            <div class="synopsis-section mb-5">
                                <h5 class="section-label">Sinopsis</h5>
                                <p class="synopsis-text text-muted" t-esc="movie['description']"/>
                            </div>

                            <div class="screenings-section">
                                <div class="screenings-header mb-4">
                                    <h5 class="section-label m-0">Sesiones para Hoy</h5>
                                    <span class="badge" t-esc="str(len(screenings)) + ' Disponibles'"/>
                                </div>
                                
                                <div class="screenings-list">
                                    <t t-foreach="screenings" t-as="screening">
                                        <div class="screening-card js_open_seat_modal" 
                                             t-att-data-session-id="screening['id']"
                                             t-att-data-movie-title="movie['title']"
                                             t-att-data-time="screening['start_time']">
                                            <div class="screening-time" t-esc="screening['start_time']"/>
                                            <div class="screening-room" t-esc="screening['room_name']"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="modal_select_seats" tabindex="-1" role="dialog" aria-hidden="true">
                    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
                        <div class="modal-content border-0 shadow-lg">
                            <div class="modal-header bg-dark text-white border-0">
                                <h5 class="modal-title font-weight-bold">Reserva de Entradas</h5>
                                <button type="button" class="close text-white" data-bs-dismiss="modal" aria-label="Close">
                                    <span>&amp;times;</span>
                                </button>
                            </div>
                            <div class="modal-body p-4 bg-light">
                                <div class="screen-container mb-5">
                                    <div class="screen-line shadow-lg"></div>
                                    <p class="text-center text-muted mt-2 small">PANTALLA</p>
                                </div>

                                <div id="seats_grid_container" class="d-flex flex-wrap justify-content-center gap-2 mb-4">
                                    <div class="text-center py-5 w-100">
                                        <i class="fa fa-circle-o-notch fa-spin fa-2x text-primary"/>
                                        <p class="mt-2 text-muted">Cargando butacas...</p>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-center gap-4 mb-2 small text-muted">
                                    <div><span class="d-inline-block rounded-circle bg-white border" style="width:12px; height:12px;"></span> Disponible</div>
                                    <div><span class="d-inline-block rounded-circle bg-primary" style="width:12px; height:12px;"></span> Tu Selección</div>
                                    <div><span class="d-inline-block rounded-circle bg-secondary" style="width:12px; height:12px;"></span> Ocupada</div>
                                </div>
                            </div>
                            
                            <div class="modal-footer bg-white border-top p-3 d-flex justify-content-between align-items-center">
                                <div class="selected-info">
                                    <small class="text-muted d-block">Asientos seleccionados:</small>
                                    <span id="js_selected_seats_summary" class="font-weight-bold text-primary">Ninguno</span>
                                </div>
                                <button type="button" id="js_btn_confirm_reserve" class="btn btn-primary btn-lg px-5 disabled" style="border-radius: 30px;">
                                    Confirmar Reserva
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="modal_reserve_success" tabindex="-1" role="dialog">
                    <div class="modal-dialog modal-dialog-centered" role="document">
                        <div class="modal-content border-0 shadow-lg text-center">
                            <div class="modal-body p-5">
                                <div class="mb-4">
                                    <div class="bg-success-light rounded-circle d-inline-flex p-4 mb-3" style="background-color: #d4edda; width: 100px; height: 100px; align-items: center; justify-content: center;">
                                        <i class="fa fa-check text-success fa-3x"/>
                                    </div>
                                </div>
                                <h2 class="font-weight-bold mb-3">¡Reserva Completada!</h2>
                                <p class="text-muted mb-4">Tu pedido ha sido generado con éxito. Hemos bloqueado tus butacas para que disfrutes de la película sin preocupaciones.</p>
                                <button type="button" class="btn btn-success btn-block btn-lg" data-bs-dismiss="modal" style="border-radius: 12px;">
                                    Entendido, ¡Gracias!
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>