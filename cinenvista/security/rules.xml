<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ====== REGLAS DE REGISTRO (RECORD RULES) ====== -->
    
    <!-- ========== REGLAS PARA ADMINISTRADOR ========== -->
    <!-- El administrador tiene acceso sin restricciones a todos los modelos -->
    
    <record id="rule_admin_unrestricted_access" model="ir.rule">
        <field name="name">Admin: Acceso sin restricciones</field>
        <field name="model_id" ref="model_cinenvista_screening"/>
        <field name="groups" eval="[(4, ref('group_cinenvista_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_admin_reservation_unrestricted" model="ir.rule">
        <field name="name">Reservation - Admin: Acceso sin restricciones</field>
        <field name="model_id" ref="model_cinenvista_reservation"/>
        <field name="groups" eval="[(4, ref('group_cinenvista_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_admin_movie_unrestricted" model="ir.rule">
        <field name="name">Movie - Admin: Acceso sin restricciones</field>
        <field name="model_id" ref="model_cinenvista_movie"/>
        <field name="groups" eval="[(4, ref('group_cinenvista_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- ========== REGLAS PARA TAQUILLERO  ========== -->
    
    <!-- REGLA 1: Visibilidad Temporal - Solo sesiones presentes/futuras -->
    <!-- Restricción: Taquillero solo ve sesiones que aún no han pasado -->
    <record id="rule_screening_box_office_future" model="ir.rule">
        <field name="name">Screening - Taquillero: Solo hoy y futuro</field>
        <field name="model_id" ref="model_cinenvista_screening"/>
        <field name="groups" eval="[(4, ref('group_cinenvista_box_office'))]"/>
        <!-- Dominio: Solo sesiones donde is_future = True -->
        <field name="domain_force">[('is_future', '=', True)]</field>
    </record>

    <!-- REGLA 2: Propiedad de Reservas -->
    <!-- Restricción: Taquillero solo puede editar las reservas que él creó -->
    <record id="rule_reservation_box_office_own" model="ir.rule">
        <field name="name">Reservation - Taquillero: Solo sus propias reservas</field>
        <field name="model_id" ref="model_cinenvista_reservation"/>
        <field name="groups" eval="[(4, ref('group_cinenvista_box_office'))]"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
    </record>

    <!-- REGLA 3: Películas Activas -->
    <!-- Restricción: Taquillero solo puede ver películas "En Cartelera" -->
    <record id="rule_movie_box_office_in_theaters" model="ir.rule">
        <field name="name">Movie - Taquillero: Solo "En Cartelera"</field>
        <field name="model_id" ref="model_cinenvista_movie"/>
        <field name="groups" eval="[(4, ref('group_cinenvista_box_office'))]"/>
        <field name="domain_force">[('state', '=', 'in_theaters')]</field>
    </record>

</odoo>
