<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================================ -->
        <!-- CUSTOM FOOTER - Override website.layout footer -->
        <!-- ============================================================ -->
        <template id="cinenvista_custom_footer" inherit_id="website.layout" name="Cinenvista Custom Footer">
            <!-- Override the footer element -->
            <xpath expr="//footer" position="replace">
                <footer class="py-5 cinenvista-footer">
                    <div class="container-fluid px-4">
                        <div class="row">
                            <!-- Left Column: Logo and Navigation -->
                            <div class="col-md-6">
                                <h5 class="mb-4">
                                 <img src="/cinenvista/static/src/images/logo.png" alt="Cinenvista Logo" class="footer-logo"/>
                                </h5>
                                <div class="footer-column">
                                    <a href="#cartelera" class="footer-link">
                                        Cartelera
                                    </a>
                                    <a href="#proximamente" class="footer-link">
                                        Próximamente
                                    </a>
                                </div>
                            </div>

                            <!-- Right Column: Additional Links -->
                            <div class="col-md-6 text-end">
                                <div class="footer-column" style="align-items: flex-end;">
                                    <a href="#contacto" class="footer-link">
                                        Contacto
                                    </a>
                                    <a href="#terminos" class="footer-link">
                                        Términos y Condiciones
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Footer Bottom -->
                        <div class="footer-bottom">
                            <p class="mb-0 footer-copyright">
                                © 2026 Cinenvista. Todos los derechos reservados.
                            </p>
                        </div>
                    </div>
                </footer>
            </xpath>
        </template>
    </data>
</odoo>
