<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================================ -->
        <!-- MAIN HOME TEMPLATE - Standalone with Header and Footer -->
        <!-- ============================================================ -->
        <template id="home_template" name="Cinenvista Home">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure">
                    <div class="container mt-5 mb-5">
                        <!-- Hero Section -->
                        <div class="text-center py-5 mb-5">
                            <h1 class="display-4 fw-bold mb-3">Bienvenido a Cinenvista</h1>
                            <p class="lead text-muted mb-0">Descubre las mejores películas del cine, en cualquier momento y lugar</p>
                            <hr class="w-50 mx-auto mt-4"/>
                        </div>

                        <!-- Movies Grid with Horizontal Scroll -->
                        <div class="movies-carousel-wrapper mb-5">
                            <!-- Left Arrow -->
                            <button class="carousel-arrow carousel-arrow-left" data-scroll="-1" title="Anterior">
                                <span>&#8249;</span>
                            </button>

                            <!-- Movies Container -->
                            <div class="movies-scroll-container">
                                <t t-if="movies">
                                    <t t-foreach="movies" t-as="movie">
                                        <div class="movie-scroll-item">
                                        <!-- Movie Card Link -->
                                        <a t-att-href="'/cine/pelicula/' + str(movie.get('id'))" class="movie-card-link" style="text-decoration: none;">
                                        <!-- Movie Card -->
                                        <div class="movie-card-container">
                                            
                                            <!-- Movie Poster Image with Rounded Top Corners -->
                                            <div class="movie-poster-container">
                                                <t t-set="movie_image" t-value="movie.get('image_url') or movie.get('image_url')"/>
                                                <t t-if="movie_image">
                                                    <img t-att-src="movie_image" alt="Poster" class="movie-poster-image"/>
                                                </t>
                                                <t t-else="">
                                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center text-white">
                                                        <span class="movie-poster-emoji">🎬</span>
                                                    </div>
                                                </t>
                                                
                                                <!-- Rating Badge (Overlay Top-Right) -->
                                                <div class="movie-rating-badge">
                                                    <span class="movie-rating-star">★</span>
                                                    <span class="movie-rating-score">
                                                        <t t-esc="movie.get('rating', 0)"/>
                                                    </span>
                                                </div>
                                            </div>

                                            <!-- Card Body -->
                                            <div class="movie-card-body">
                                                <!-- Movie Title -->
                                                <h5 class="movie-card-title">
                                                    <t t-esc="movie.get('title', 'Sin título')"/>
                                                </h5>
                                                
                                                <!-- Tags Container -->
                                                <div class="movie-tags-container">
                                                    <t t-set="tags" t-value="movie.get('tag_ids', [])"/>
                                                    <t t-if="len(tags) > 0">
                                                        <t t-foreach="tags" t-as="tag">
                                                            <!-- Color Pill Tags with Dynamic Color -->
                                                            <t t-set="tag_hex_color" t-value="tag.get('hex_color', '#BDBDBD')"/>
                                                            <span class="movie-tag-pill" t-att-style="'background-color: ' + tag_hex_color + '; color: white;'">
                                                                <t t-esc="tag.get('name', '')"/>
                                                            </span>
                                                        </t>
                                                    </t>
                                                </div>
                                            </div>
                                        </div>
                                        </a>
                                    </div>
                                </t>
                            </t>
                            </div>

                            <!-- Right Arrow -->
                            <button class="carousel-arrow carousel-arrow-right" data-scroll="1" title="Siguiente">
                                <span>&#8250;</span>
                            </button>
                        </div>
                        <t t-if="not movies">
                            <div class="row">
                                <div class="col-12 text-center py-5">
                                    <p class="text-muted fs-5">No hay películas disponibles en este momento.</p>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </template>

        <!-- ============================================================ -->
        <!-- Movie Carousel Script -->
        <!-- ============================================================ -->
        <template id="movie_carousel_script" inherit_id="website.layout" name="Movie Carousel Script">
            <xpath expr="//body" position="inside">
                <script src="/cinenvista/static/src/js/movie_carousel.js"></script>
            </xpath>
        </template>

        <!-- ============================================================ -->
        <!-- WEBSITE MENU ENTRY -->
        <!-- ============================================================ -->
        <record id="cinenvista_menu" model="website.menu">
            <field name="name">Cinenvista</field>
            <field name="url">/cine</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">1</field>
        </record>
    </data>
</odoo>