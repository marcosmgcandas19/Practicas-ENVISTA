<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================================ -->
        <!-- CUSTOM HEADER - Override website.layout header -->
        <!-- ============================================================ -->
        <template id="cinenvista_custom_header" inherit_id="website.layout" name="Cinenvista Custom Header">
            <!-- Override the header element -->
            <xpath expr="//header" position="replace">
                <header class="sticky-top cinenvista-header">
                    <div class="container-fluid px-4">
                        <!-- Floating Navbar Container (Pill Style) -->
                        <div class="navbar-pill-container">
                            
                            <!-- Left Section: Cartelera Button -->
                            <div class="navbar-left">
                                <a href="#cartelera" class="navbar-btn-success">
                                    Cartelera
                                </a>
                                <a href="#proximamente" class="navbar-btn-outline">
                                    Próximamente
                                </a>
                            </div>

                            <!-- Center: Logo -->
                            <a href="/cine" class="navbar-center navbar-brand">
                                <img src="/cinenvista/static/src/images/logo.png" alt="Cinenvista Logo" class="navbar-logo"/>
                            </a>

                            <!-- Right Section: User Avatar -->
                            <div class="navbar-right">
                                <a href="/web/login" class="user-avatar">
                                    <img src="/cinenvista/static/src/images/user.png" alt="User Profile"/>
                                </a>
                            </div>
                        </div>
                    </div>
                </header>
            </xpath>
        </template>
    </data>
</odoo>
