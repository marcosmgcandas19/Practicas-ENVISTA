<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="movie_template" name="Cinenvista Movie Detail">
            <t t-call="website.layout">
                <t t-set="additional_title">
                    <t t-esc="movie.get('title', 'Película')"/> - Cinenvista
                </t>

                <div class="container-fluid px-4 py-5 cinenvista-movie-detail">
                    <div class="row g-4">
                        <div class="col-lg-3 col-md-12">
                            <div class="movie-poster-container">
                                <img t-att-src="movie.get('image_url', '')" 
                                     t-att-alt="movie.get('title', 'Película')" 
                                     class="movie-poster img-fluid rounded-lg"/>
                            </div>
                        </div>

                        <div class="col-lg-5 col-md-12">
                            <div class="movie-header mb-4">
                                <h1 class="movie-title display-5 fw-bold">
                                    <t t-esc="movie.get('title', 'Sin título')"/>
                                </h1>
                            </div>

                            <div class="synopsis-section mb-4">
                                <h3 class="section-label fw-bold mb-3">Sinópsis</h3>
                                <p class="synopsis-text">
                                    <t t-esc="movie.get('description', '')"/>
                                </p>
                            </div>

                            <div class="screenings-section">
                                <div class="screenings-header bg-light rounded-lg p-3 mb-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <h3 class="section-label fw-bold mb-0">Sesiones</h3>
                                        <span class="badge bg-success">Hoy</span>
                                    </div>
                                </div>
                                <div class="screenings-list d-flex flex-wrap gap-3">
                                    <t t-if="screenings">
                                        <t t-foreach="screenings" t-as="screening">
                                            <div class="screening-card bg-success text-white rounded-lg p-3 d-flex flex-column align-items-center" style="min-width: 120px; cursor: pointer;" t-att-data-session-id="screening.get('id')" onclick="openSeatModal(this);">
                                                <div class="screening-time fw-bold" style="font-size: 1.25rem;">
                                                    <t t-esc="screening.get('start_time').strftime('%H:%M') if screening.get('start_time') else 'N/A'"/>
                                                </div>
                                                <div class="screening-room fw-normal">
                                                    <t t-esc="screening.get('room_name', 'Sala')"/>
                                                </div>
                                            </div>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <p class="text-muted">No hay sesiones disponibles para hoy.</p>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 col-md-12">
                            <div class="movie-metadata">
                                <div class="metadata-section mb-4">
                                    <h4 class="metadata-label fw-bold mb-2">Géneros</h4>
                                    <div class="genres-list d-flex flex-wrap gap-2">
                                        <t t-if="movie.get('tag_ids')">
                                            <t t-foreach="movie.get('tag_ids')" t-as="tag">
                                                <span class="badge rounded-pill" t-attf-style="background-color: {{tag.get('hex_color', '#6c757d')}};">
                                                    <t t-esc="tag.get('name')"/>
                                                </span>
                                            </t>
                                        </t>
                                        <t t-else=""><p class="text-muted">Sin géneros</p></t>
                                    </div>
                                </div>

                                <div class="metadata-section mb-3">
                                    <p class="mb-0">
                                        <strong>Duración:</strong> 
                                        <t t-if="movie.get('duration')">
                                            <t t-esc="int(movie.get('duration'))"/> min
                                        </t>
                                        <t t-else="">N/A</t>
                                    </p>
                                </div>

                                <div class="metadata-section mb-3">
                                    <p class="mb-0">
                                        <strong>Fecha de estreno:</strong> 
                                        <t t-if="movie.get('release_date')">
                                            <t t-esc="movie.get('release_date')"/>
                                        </t>
                                        <t t-else=""><span class="text-muted">Próximamente</span></t>
                                    </p>
                                </div>

                                <div class="metadata-section">
                                    <p class="mb-0">
                                        <strong>Puntuación:</strong> 
                                        <t t-esc="movie.get('rating', 0.0)"/>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- MODAL: SELECCIÓN DE BUTACAS -->
                <div id="seatSelectionModal" class="cinenvista-modal hidden">
                    <div class="cinenvista-modal-backdrop" onclick="closeSeatModal();"></div>
                    <div class="cinenvista-modal-content">
                        <!-- Encabezado -->
                        <div class="cinenvista-modal-header">
                            <h2 class="modal-title">Selecciona tus butacas</h2>
                            <button class="modal-close-btn" onclick="closeSeatModal();">✕</button>
                        </div>

                        <!-- Pantalla del Cine -->
                        <div class="cinema-screen">
                            <div class="screen-label">Pantalla</div>
                        </div>

                        <!-- Mapa de Butacas (se inyectará dinámicamente) -->
                        <div class="seats-container" id="seatsGrid">
                            <div class="loading-spinner">Cargando butacas...</div>
                        </div>

                        <!-- Resumen de Selección -->
                        <div class="selection-summary">
                            <div class="summary-content">
                                <h4 class="summary-title">Butacas seleccionadas:</h4>
                                <div class="selected-seats-list" id="selectedSeatsList">
                                    <span class="empty-message">Ninguna butaca seleccionada</span>
                                </div>
                            </div>
                            <div class="summary-actions">
                                <button class="btn btn-secondary btn-sm" onclick="closeSeatModal();">Cancelar</button>
                                <button class="btn btn-success btn-sm" id="confirmSeatsBtn" onclick="confirmSelection();" disabled="disabled">Confirmar</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- MODAL: CONFIRMACIÓN DE ÉXITO -->
                <div id="successModal" class="cinenvista-modal hidden">
                    <div class="cinenvista-modal-backdrop"></div>
                    <div class="cinenvista-modal-success">
                        <div class="success-content">
                            <img src="/cinenvista/static/src/images/reserva.png" alt="Éxito" class="success-icon mb-3"/>
                            <h2 class="success-title">¡Reserva Confirmada!</h2>
                            <button class="btn btn-primary btn-lg" onclick="redirectToHome();">Gracias</button>
                        </div>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>